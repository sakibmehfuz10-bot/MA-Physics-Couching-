rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isVerified() {
      // In a real app we'd enforce email verified, but for rapid prototyping we might tolerate standard sign in
      // return request.auth.token.email_verified == true;
      return true;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function isAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'mehfuzsakib10@gmail.com' ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'teacher'])
      );
    }
    
    // User Profile Validation
    function isValidUserProfile(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
        data.uid == request.auth.uid &&
        data.role in ['student', 'teacher', 'admin'];
    }

    match /users/{userId} {
      allow get: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isSignedIn() && 
                    userId == request.auth.uid &&
                    isValidId(userId) &&
                    isValidUserProfile(incoming()); // Relax the strictly 'student' only if they are teacher
                    
      allow update: if isSignedIn() &&
                    userId == request.auth.uid &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['lastLoginAt']);
    }

    // Student Profile Validation
    function isValidStudentProfile(data) {
      return data.keys().hasAll(['ownerUid', 'googleEmail', 'firstName', 'lastName', 'dateOfBirth', 'gender', 'classLevel', 'academicYear', 'parentContactNumber', 'createdAt']) &&
        data.ownerUid == request.auth.uid;
    }

    match /studentProfiles/{profileId} {
      allow get: if isSignedIn();
      allow list: if isSignedIn();
      
      allow create: if isSignedIn() && 
                    profileId == request.auth.uid && 
                    isValidId(profileId) &&
                    isValidStudentProfile(incoming());

      allow update: if isSignedIn() && 
                    profileId == request.auth.uid &&
                    isValidId(profileId) &&
                    isValidStudentProfile(incoming()) &&
                    incoming().ownerUid == existing().ownerUid &&
                    incoming().createdAt == existing().createdAt;
    }

    match /mail/{mailId} {
      allow create: if isSignedIn() && incoming().to == request.auth.token.email;
    }

  }
}
